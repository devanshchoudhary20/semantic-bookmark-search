{
  "manifest_version": 3,
  "name": "Semantic Bookmark Search",
  "version": "0.2.0",
  "description": "Search your bookmarks by meaning, not exact text — fully on-device, no account.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["bookmarks", "storage", "tabs"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' data: blob:;"
  },
  "web_accessible_resources": [
    {
      "resources": ["ort/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
